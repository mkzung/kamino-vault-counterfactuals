    given-names: Max
    affiliation: "Stanford GSB Venture Capital Initiative"
repository-code: "https://github.com/mkzung/kamino-vault-counterfactuals"
license: MIT
version: 0.1.1
date-released: 2026-05-21
keywords:
  - DeFi
  - Solana
  - Kamino
  - lending
  - risk
  - counterfactual
